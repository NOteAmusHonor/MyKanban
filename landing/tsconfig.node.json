{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": ["vite.config.*", "scripts/**/*"],
  "compilerOptions": {
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "allowJs": true,
    "checkJs": false
  }
}
