{
  "name": "@mykanban/board",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Modern, local-first Kanban board with AI integration",
  "main": "dist/mykanban.umd.cjs",
  "module": "dist/mykanban.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mykanban.js",
      "require": "./dist/mykanban.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "bin": {
    "mykanban": "./bin/mykanban.mjs"
  },
  "files": [
    "dist",
    "server",
    "bin",
    "kanban.schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/deinusername/mykanban.git"
  },
  "keywords": [
    "kanban",
    "vue",
    "vue3",
    "pinia",
    "project-management",
    "task-management",
    "ai-integration"
  ],
  "scripts": {
    "dev": "vite",
    "server": "node server/index.mjs",
    "start": "node bin/mykanban.mjs",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:library": "cross-env BUILD=library vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write --experimental-cli src/"
  },
  "peerDependencies": {
    "pinia": "^3.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "express": "^5.2.1",
    "marked": "^17.0.6",
    "open": "^11.0.0",
    "pinia": "^3.0.0",
    "sirv": "^3.0.2",
    "vue": "^3.5.0",
    "vue-router": "^5.0.4",
    "vuedraggable": "^4.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
